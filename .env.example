# Tachyon Configuration
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

TACHYON_SESSION=your_higgs_session_value_here
TACHYON_USER_ID=your_user_id_here
TACHYON_PRESET_ID=your_preset_id_here

# =============================================================================
# LangChain / TachyonLangchainClient Configuration
# Required for the LangChain-powered chat endpoint.
# =============================================================================

# (Optional) Override the default Tachyon playground LLM endpoint
# TACHYON_LLM_URL=https://tachyon-studio.institute.net/playground_document_llm

# =============================================================================
# Knowledge Source Configuration (Hardcoded)
# Configure Tachyon File/Folder IDs for each source type.
# A source is automatically activated if at least one ID (file or folder) is provided.
# Leave both empty to disable a source type.
# =============================================================================

# Jira Dump - Historical Jira tickets and issues
JIRA_TACHYON_FILE_ID=
JIRA_TACHYON_FOLDER_ID=

# Incident Tickets - Production incident records
INCIDENT_TACHYON_FILE_ID=
INCIDENT_TACHYON_FOLDER_ID=

# Past Solutions - Known solutions and resolutions
SOLUTION_TACHYON_FILE_ID=
SOLUTION_TACHYON_FOLDER_ID=

# Codebase - Source code files for lookup
# You can provide multiple file IDs separated by commas or semicolons.
CODE_TACHYON_FILE_ID=
CODE_TACHYON_FOLDER_ID=

# =============================================================================
# Legacy single ID configuration (deprecated - use source-specific IDs above)
# These are used as fallback if no source-specific IDs are configured
# =============================================================================
TACHYON_FOLDER_ID=your_folder_id_here
TACHYON_FILE_ID=your_file_id_here
